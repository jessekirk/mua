  </sevenZ>
  <args>a</args>
  <args>-mx9</args>
  <args>-mmt3</args>
  <args>-md=2048m</args>
  <args>-m0=lzma2:fb64</args>
  <args>-ms=16384m</args>
  <args>-bt</args>
